# Shelby AI Evidence Vault — environment variable template
# Copy this file to .env.local and fill in real values for testnet mode.
# NEVER commit .env.local or any file containing real secrets.

# ── Shelby adapter mode ──────────────────────────────────────────────────────
# Set to "testnet" to use the real Shelby testnet adapter.
# Omit or set to "mock" (default) to run with deterministic mock data.
# Mock mode requires no other variables and works with no network access.
SHELBY_MODE=mock

# ── Shelby testnet credentials (required only when SHELBY_MODE=testnet) ──────
# RPC endpoint for the Shelby testnet node.
SHELBY_TESTNET_RPC_URL=

# API key for authenticated Shelby testnet requests.
# Keep this server-side only — never expose via NEXT_PUBLIC_ prefix.
SHELBY_API_KEY=

# Your Shelby testnet account address (public, not a secret).
SHELBY_ACCOUNT_ADDRESS=

# ── Notes ────────────────────────────────────────────────────────────────────
# • The real Shelby testnet adapter is a documented placeholder in M1.
#   See src/lib/shelby/testnet-adapter.ts for implementation notes.
# • File uploads are stored in browser localStorage only — no server DB.
# • SHA-256 hashes are computed client-side using the Web Crypto API.
# • Setting SHELBY_MODE=testnet currently fails on upload with a clear error
#   until the SDK is wired in (M2). Mock mode is fully functional.
