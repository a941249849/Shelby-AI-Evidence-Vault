# Shelby AI Evidence Vault — environment variable template
# Copy this file to .env.local and fill in real values for testnet mode.
# NEVER commit .env.local or any file containing real secrets.
# NEVER add private keys, seed phrases, or signing material here.

# ── Adapter mode ─────────────────────────────────────────────────────────────
# Set to "testnet" to enable the Shelby testnet adapter (M2+, placeholder in M1).
# Omit or set to "mock" (default) to run with deterministic mock data — no network needed.
SHELBY_MODE=mock

# ════════════════════════════════════════════════════════════════════════════
# PLANE 1: Shelby storage / RPC plane
# Variables specific to Shelby's own blob storage and API layer.
# The Shelby RPC layer runs on shelbynet (an isolated Aptos-derived network).
# ════════════════════════════════════════════════════════════════════════════

# Shelby network name. The production testnet network is "shelbynet".
# Used as a label/selection key — does not point to a node directly.
SHELBY_NETWORK=shelbynet

# Shelby RPC endpoint for blob upload and storage operations.
# Official shelbynet value: https://api.shelbynet.shelby.xyz/shelby
# Server-side only — never expose via NEXT_PUBLIC_ prefix.
SHELBY_RPC_URL=

# API key for authenticated Shelby storage requests (if required).
# Server-side only — never set NEXT_PUBLIC_SHELBY_API_KEY.
SHELBY_API_KEY=

# Your Shelby account address on shelbynet (public identifier, not a secret).
SHELBY_ACCOUNT_ADDRESS=

# Blob upload expiration in microseconds (required for real Shelby uploads).
# Real uploads to Shelby must include an expiration. Example: 1800000000 (30 min).
# Not consumed in M1 mock mode. Must be set before enabling testnet upload (M2+).
SHELBY_BLOB_EXPIRATION_MICROS=

# ════════════════════════════════════════════════════════════════════════════
# PLANE 2: Shelbynet / Aptos coordination plane
# Variables for Aptos-layer network connectivity on shelbynet.
# Shelbynet is its own isolated Aptos-derived network — NOT generic Aptos testnet.
# These are not used in M1; documented here for M2+ planning.
# ════════════════════════════════════════════════════════════════════════════

# Aptos network identifier for shelbynet. Must be "shelbynet" (not "testnet").
# Shelbynet is an isolated Aptos-derived chain, not the public Aptos testnet.
APTOS_NETWORK=shelbynet

# Shelbynet Aptos fullnode REST API URL.
# Official shelbynet value: https://api.shelbynet.shelby.xyz/v1
# Used for reading on-chain state. Signing/transactions are NOT part of M1.
SHELBYNET_APTOS_FULLNODE_URL=

# Shelbynet indexer GraphQL API URL (optional; needed for indexed queries).
# Official shelbynet value: https://api.shelbynet.shelby.xyz/v1/graphql
SHELBYNET_INDEXER_URL=

# Shelbynet faucet URL (for funding test accounts during local development).
SHELBYNET_FAUCET_URL=

# Your account address on the shelbynet Aptos coordination layer (public, not a secret).
# Separate from SHELBY_ACCOUNT_ADDRESS (Plane 1) above.
SHELBYNET_ACCOUNT_ADDRESS=

# ── Notes ────────────────────────────────────────────────────────────────────
# • Shelbynet is its own isolated network, not the public Aptos testnet.
#   Do NOT use generic Aptos testnet URLs with Shelby — they are incompatible.
# • SHELBY_RPC_URL (Plane 1) is Shelby's blob storage API, distinct from the
#   Aptos fullnode at SHELBYNET_APTOS_FULLNODE_URL (Plane 2). Do not conflate.
# • Shelby coordination contract on shelbynet:
#   0xc63d6a5efb0080a6029403131715bd4971e1149f7cc099aac69bb0069b3ddbf5
#   Explorer: https://explorer.shelby.xyz/shelbynet
# • Real Shelby uploads (M2+) require:
#   - APT on shelbynet for transaction gas fees
#   - ShelbyUSD or SHEL tokens for Shelby storage operations
#   - A SHELBY_BLOB_EXPIRATION_MICROS value set for each upload
#   - on-chain commitment registration before the RPC putBlob call
#   Account signing must be handled server-side or via a secure wallet —
#   NEVER by committing private keys or seed phrases.
# • The real Shelby testnet adapter is a documented placeholder in M1.
#   See src/lib/shelby/testnet-adapter.ts for implementation notes.
# • File uploads are stored in browser localStorage only — no server DB in M1.
# • SHA-256 hashes are computed client-side using the Web Crypto API.
# • SHELBY_MODE=testnet fails on upload until the SDK is wired in (M2).
#   Mock mode is fully functional with zero env vars.
