# Shelby AI Evidence Vault — environment variable template
# Copy this file to .env.local and fill in real values for testnet mode.
# NEVER commit .env.local or any file containing real secrets.
# NEVER add private keys, seed phrases, or signing material here.

# ── Adapter mode ─────────────────────────────────────────────────────────────
# Set to "testnet" to enable the Shelby testnet adapter (browser wallet upload).
# Omit or set to "mock" (default) to run local demo mode — no network needed, no env vars needed.
SHELBY_MODE=mock

# ════════════════════════════════════════════════════════════════════════════
# PLANE 1: Shelby storage / RPC plane (server-side)
# Variables specific to Shelby's own blob storage and API layer.
# Current real-integration planning targets the official Shelby testnet.
# ════════════════════════════════════════════════════════════════════════════

# Shelby network name. Use "testnet" for the current production-shaped testnet.
# Used as a label/selection key — does not point to a node directly.
SHELBY_NETWORK=testnet

# Shelby RPC endpoint for blob upload and storage operations.
# Official testnet value: https://api.testnet.shelby.xyz/shelby
# Server-side only — never expose via NEXT_PUBLIC_ prefix.
SHELBY_RPC_URL=

# API key for authenticated Shelby storage requests (if required).
# Server-side only — never set NEXT_PUBLIC_SHELBY_API_KEY.
SHELBY_API_KEY=

# Your Shelby account address on the selected network (public identifier, not a secret).
SHELBY_ACCOUNT_ADDRESS=

# Blob upload expiration in microseconds (required for real Shelby uploads).
# Real uploads to Shelby must include an expiration. Example: 1800000000 (30 min).
# Not consumed in mock mode. Must be set before enabling testnet upload.
SHELBY_BLOB_EXPIRATION_MICROS=

# ════════════════════════════════════════════════════════════════════════════
# PLANE 2: Aptos coordination plane (server-side)
# Variables for Aptos-layer network connectivity.
# These are not used in mock mode; documented here for reference.
# ════════════════════════════════════════════════════════════════════════════

# Aptos network identifier for the current Shelby testnet target.
APTOS_NETWORK=testnet

# Aptos fullnode REST API URL.
# Official testnet value: https://api.testnet.aptoslabs.com/v1
SHELBY_APTOS_FULLNODE_URL=

# Aptos indexer GraphQL API URL (optional; needed for indexed queries).
# Official testnet value: https://api.testnet.aptoslabs.com/v1/graphql
SHELBY_INDEXER_URL=

# Faucet/funding URL, if Shelby documents one for the selected network.
SHELBY_FAUCET_URL=

# Your account address on the Aptos coordination layer (public, not a secret).
# Separate from SHELBY_ACCOUNT_ADDRESS (Plane 1) above.
SHELBY_COORDINATION_ACCOUNT_ADDRESS=

# ════════════════════════════════════════════════════════════════════════════
# BROWSER-SIDE (NEXT_PUBLIC_) CONFIGURATION
# Safe to expose — these are public endpoint URLs and non-secret settings.
# Used by the browser wallet upload path (useShelbyUpload hook).
# NEVER add NEXT_PUBLIC_SHELBY_API_KEY here — API keys must stay server-side.
# ════════════════════════════════════════════════════════════════════════════

# Shelby network for browser-side SDK config.
# Must match the server-side SHELBY_NETWORK above.
# Values: testnet | shelbynet (default: testnet)
NEXT_PUBLIC_SHELBY_NETWORK=testnet

# Optional override for Shelby RPC base URL (browser SDK).
# Defaults to the SDK's built-in testnet URL if not set.
# Official testnet value: https://api.testnet.shelby.xyz/shelby
NEXT_PUBLIC_SHELBY_RPC_URL=

# Optional override for Shelby indexer URL (browser SDK).
# Official testnet value: https://api.testnet.aptoslabs.com/nocode/v1/public/alias/shelby/testnet/v1/graphql
NEXT_PUBLIC_SHELBY_INDEXER_URL=

# Blob lifetime in hours for browser wallet uploads (default: 24).
# Uploads will expire this many hours from the time of upload.
NEXT_PUBLIC_SHELBY_EXPIRATION_HOURS=24

# ── Notes ────────────────────────────────────────────────────────────────────
# • Shelby's older shelbynet developer-prototype endpoints are legacy context.
#   Do NOT mix shelbynet and testnet endpoint values in one runtime config.
# • SHELBY_RPC_URL (Plane 1) is Shelby's blob storage API, distinct from the
#   Aptos fullnode at SHELBY_APTOS_FULLNODE_URL (Plane 2). Do not conflate.
# • Real Shelby uploads require:
#   - A connected Aptos browser wallet (Petra, etc.)
#   - Testnet APT for transaction gas fees
#   - ShelbyUSD or SHEL tokens for Shelby storage operations
#   - NEXT_PUBLIC_SHELBY_NETWORK=testnet (or SHELBY_MODE=testnet server-side)
#   Account signing is handled by the browser wallet — no private key custody.
# • M1B mock mode: no wallet signing, no network calls, no real Shelby upload.
#   SHELBY_MODE=mock (or unset) uses the local demo adapter only.
# • File uploads are stored in browser localStorage — no server DB.
# • SHA-256 hashes are computed client-side using the Web Crypto API.
# • SHELBY_DEPLOYER contract: 0x85fdb9a176ab8ef1d9d9c1b60d60b3924f0800ac1de1cc2085fb0b8bb4988e6a
#   (from official Shelby Networks page — SDK uses this constant internally).
