# Shelby AI Evidence Vault — environment variable template
# Copy this file to .env.local and fill in real values for testnet mode.
# NEVER commit .env.local or any file containing real secrets.
# NEVER add private keys, seed phrases, or signing material here.

# ── Adapter mode ─────────────────────────────────────────────────────────────
# Set to "testnet" to enable the Shelby testnet adapter (M2+, placeholder in M1).
# Omit or set to "mock" (default) to run with deterministic mock data — no network needed.
SHELBY_MODE=mock

# ════════════════════════════════════════════════════════════════════════════
# PLANE 1: Shelby storage / RPC plane
# Variables specific to Shelby's own storage and blob API layer.
# ════════════════════════════════════════════════════════════════════════════

# Shelby RPC / API endpoint for blob upload and storage operations.
# This is Shelby's own storage API — distinct from the Aptos fullnode below.
# Keep server-side only — never expose via NEXT_PUBLIC_ prefix.
SHELBY_RPC_URL=

# API key for authenticated Shelby storage requests.
# Server-side only — never set NEXT_PUBLIC_SHELBY_API_KEY.
SHELBY_API_KEY=

# Your Shelby storage account address (public identifier, not a secret).
SHELBY_ACCOUNT_ADDRESS=

# ════════════════════════════════════════════════════════════════════════════
# PLANE 2: Aptos testnet coordination plane
# Variables for Aptos network connectivity, needed when Shelby is coordinated
# via Aptos on-chain state. Not used in M1; documented here for M2+ planning.
# ════════════════════════════════════════════════════════════════════════════

# Aptos network identifier (e.g. "testnet", "devnet", "mainnet").
# Does not point to a specific node — used as a label/selection key.
APTOS_NETWORK=testnet

# Aptos testnet fullnode REST API URL.
# Used for reading on-chain state (not for signing or sending transactions in M1).
APTOS_FULLNODE_URL=

# Aptos testnet indexer GraphQL URL (optional; needed for indexed queries).
APTOS_INDEXER_URL=

# Aptos testnet faucet URL (for funding test accounts during local development).
APTOS_FAUCET_URL=

# Your Aptos testnet account address (public identifier, not a secret).
# This is separate from SHELBY_ACCOUNT_ADDRESS above.
APTOS_ACCOUNT_ADDRESS=

# ── Notes ────────────────────────────────────────────────────────────────────
# • The Shelby storage plane and Aptos coordination plane are distinct.
#   SHELBY_RPC_URL is Shelby's own blob API; APTOS_FULLNODE_URL is the
#   Aptos L1/L2 node. Do not conflate them.
# • The real Shelby testnet adapter is a documented placeholder in M1.
#   See src/lib/shelby/testnet-adapter.ts for implementation notes.
# • Aptos transaction signing and account management are NOT part of M1.
#   When required in a future milestone, signing must be handled server-side
#   or via a secure wallet integration — never by committing private keys.
# • File uploads are stored in browser localStorage only — no server DB in M1.
# • SHA-256 hashes are computed client-side using the Web Crypto API.
# • Setting SHELBY_MODE=testnet currently fails on upload with a clear error
#   until the SDK is wired in (M2). Mock mode is fully functional.
